{
  "name": "remindus-backend",
  "version": "1.0.0",
  "private": true,
  "description": "RemindUs Buddy — Node.js Express API",
  "main": "src/app.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon src/app.js",
    "dev:staging": "cross-env NODE_ENV=staging nodemon src/app.js",
    "start": "cross-env NODE_ENV=production node src/app.js",
    "seed": "cross-env NODE_ENV=development node src/seed/seed.js",
    "lint": "eslint src/ --ext .js",
    "test": "jest --coverage",
    "test:watch": "jest --watchAll"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
